# =============================================================================
# RAG Studio Pro — environment configuration
# Copy to `.env` and fill in. `.env` is git-ignored.
# Phase 0: only infra credentials are required to bring the stack up.
# Provider API keys can stay blank until their phase.
# =============================================================================

# ---- Frontend (Next.js) -----------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---- Clerk authentication (REQUIRED from Phase 1) ---------------------------
# Both come from your Clerk dashboard (https://dashboard.clerk.com).
# The publishable key is shared with the backend (it derives the JWKS/issuer);
# the secret key lets the backend read user profiles.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ---- PostgreSQL -------------------------------------------------------------
POSTGRES_USER=ragstudio
POSTGRES_PASSWORD=ragstudio
POSTGRES_DB=ragstudio
# Consumed by the backend (host = docker service name)
DATABASE_URL=postgresql+psycopg://ragstudio:ragstudio@postgres:5432/ragstudio

# ---- Redis (cache + Celery broker) ------------------------------------------
REDIS_URL=redis://redis:6379/0

# ---- Qdrant (vector DB) -----------------------------------------------------
QDRANT_URL=http://qdrant:6333

# ---- Neo4j (graph DB) -------------------------------------------------------
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=ragstudio123

# ---- MinIO (S3-compatible object storage) -----------------------------------
MINIO_ROOT_USER=ragstudio
MINIO_ROOT_PASSWORD=ragstudio123
MINIO_ENDPOINT=http://minio:9000

# ---- LLM / Embedding providers (added per phase) ----------------------------
# Active generation provider (Phase 3): gemini | groq
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ---- Observability (Phase 8) ------------------------------------------------
# LangSmith tracing for LangGraph runs (optional; leave blank to disable).
LANGSMITH_API_KEY=
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ---- Reliability & limits (Phase 8) -----------------------------------------
# Fallback LLM provider tried if the primary fails (e.g. groq). Blank = none.
LLM_FALLBACK_PROVIDER=
RATE_LIMIT_PER_MINUTE=30
ORG_DAILY_QUOTA=1000

# ---- Host port mappings -----------------------------------------------------
# Only affect how services are reached FROM THE HOST; containers always talk to
# each other on standard ports over the internal Docker network. Override any
# that collide with services already running on your machine.
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
QDRANT_HOST_PORT=6333
QDRANT_GRPC_HOST_PORT=6334
NEO4J_HTTP_HOST_PORT=7474
NEO4J_BOLT_HOST_PORT=7687
MINIO_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
BACKEND_HOST_PORT=8000
FRONTEND_HOST_PORT=3000
